# ─── LLM APIs ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
# Optional base URL override (e.g. for OpenRouter: https://openrouter.ai/api/v1)
# OPENAI_BASE_URL=
OPENAI_TTS_API_KEY=your_openai_api_key_here

# ─── Text-to-Speech ──────────────────────────────────────────────────────────
# Options: "openai" | "google" | "elevenlabs"
TTS_PROVIDER=google
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
GOOGLE_TTS_LANGUAGE=en-US
GOOGLE_TTS_VOICE_NAME=en-US-Journey-D

ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id_here

# ─── Rendering ───────────────────────────────────────────────────────────────
# Set to "720p" (default) or "1080p"
RENDER_RESOLUTION=720p

# ─── Subtitles ────────────────────────────────────────────────────────────────
# Enable/disable subtitle burning into final video
SUBTITLE_ENABLED=true
# Subtitle display language (can differ from TTS speech language)
# Options: en, zh-TW, zh-CN, ja, ko, es, fr, de, pt, ar
SUBTITLE_LANGUAGE=zh-TW

# ─── YouTube (OAuth2) ────────────────────────────────────────────────────────
YOUTUBE_CLIENT_ID=your_youtube_oauth_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_oauth_client_secret_here

# ─── Instagram (Graph API) ───────────────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=your_instagram_graph_api_token_here
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id_here

# ─── LLM Model Selection ─────────────────────────────────────────────────────
# Scriptwriter / supervisor / routing agent
LLM_MODEL=gpt-5
# Animator: code generation needs a stronger model
ANIMATOR_MODEL=gpt-5.1-codex

# ─── RAG / ChromaDB ──────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=rag/chroma_db
